							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123!@#\",\n  \"confirmPassword\": \"Password123!@#\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
