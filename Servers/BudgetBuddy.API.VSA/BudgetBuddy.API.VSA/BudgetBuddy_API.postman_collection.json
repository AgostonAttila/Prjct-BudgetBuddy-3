						},
						"url": {
							"raw": "{{baseUrl}}/api/twofactor/verify",
							"host": ["{{baseUrl}}"],
							"path": ["api", "twofactor", "verify"]
						},
						"description": "Verify TOTP code from authenticator app and complete 2FA setup\n\n**Security:** Rate limited to 5 attempts per 15 minutes (brute force protection)"
					}
				},
				{
					"name": "Disable Two-Factor",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"password\": \"Test123!@#\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/twofactor/disable",
							"host": ["{{baseUrl}}"],
							"path": ["api", "twofactor", "disable"]
						},
						"description": "Disable 2FA for current user (requires password confirmation for security)"
					}
				},
				{
					"name": "Get Recovery Codes (Generate New)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/twofactor/recovery-codes?generateNew=true&batchNumber=1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "twofactor", "recovery-codes"],
							"query": [
								{
									"key": "generateNew",
									"value": "true",
									"description": "Generate new recovery codes (invalidates old ones)"
								},
								{
									"key": "batchNumber",
									"value": "1",
									"description": "Batch number (1 or 2) - returns 5 codes per batch"
								}
							]
						},
						"description": "Generate 10 new recovery codes (returns first 5)\n\n**Security Features:**\n- Batched distribution (2 batches of 5 codes)\n- Codes hashed before storage\n- 15-minute cache expiration\n- Strict rate limiting\n- Single-use codes"
					}
				},
				{
					"name": "Get Recovery Codes (Batch 2)",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/twofactor/recovery-codes?batchNumber=2",
							"host": ["{{baseUrl}}"],
							"path": ["api", "twofactor", "recovery-codes"],
							"query": [
								{
									"key": "batchNumber",
									"value": "2",
									"description": "Retrieve remaining 5 codes (batch 2)"
								}
							]
						},
						"description": "Retrieve remaining recovery codes from cache (batch 2 of 2)"
					}
				}
			]
		},
