{
  "Jwt": {
    "_comment": "SecretKey must be provided via environment variable Jwt__SecretKey in CI/CD. Never commit a real secret here.",
    "SecretKey": ""
  },
  "RateLimit": {
    "Fixed":    { "PermitLimit": 100000, "WindowMinutes": 1, "QueueLimit": 10000 },
    "FixedByIp": { "PermitLimit": 100000, "WindowMinutes": 1, "QueueLimit": 10000 },
    "Auth":     { "TokenLimit": 10000, "ReplenishmentPeriodMinutes": 1, "TokensPerPeriod": 10000 },
    "Global":   { "PermitLimit": 100000, "WindowMinutes": 1 },
    "Api":      { "PermitLimit": 100000, "WindowMinutes": 1, "SegmentsPerWindow": 6, "QueueLimit": 10000 }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
